generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
}

// Users 

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  teacher   Teacher?
  auditLogs AuditLog[]
}

//School
model School {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  email     String?
  motto     String?
  logoUrl   String?
  website   String?
  accountName String?
  accountNumber String?
  bankName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Sessions & Terms 
// A Session = academic year e.g. "2024/2025"
// A Term    = one of three periods within a session e.g. "First Term"

model Session {
  id        String   @id @default(cuid())
  name      String   @unique   // e.g. "2024/2025"
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  terms     Term[]
}

model Term {
  id        String   @id @default(cuid())
  name      String
  sessionId String

  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  isCurrent Boolean  @default(false)

  startDate DateTime?
  endDate   DateTime?

  schoolOpened Int? @default(0)

  createdAt DateTime @default(now())

  payments            Payment[]
  optionalFeeAssigns  OptionalFeeAssign[]
  results             Result[]
  assessments         Assessment[]
  attendanceSummaries AttendanceSummary[]

  @@unique([sessionId, name])
}

// Teachers 

model Teacher {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  classId     String?
  class       Class?   @relation(fields: [classId], references: [id])
  subjectName String?
  createdAt   DateTime @default(now())
}

//Classes

model Class {
  id        String    @id @default(cuid())
  className String    @unique
  feeAmount Float
  createdAt DateTime  @default(now())
  students  Student[]
  subjects  Subject[]
  teachers  Teacher[]
}

//  Students 

model Student {
  id              String   @id @default(cuid())
  admissionNumber String   @unique
  name            String

  // Parent Information
  parentName      String?
  parentPhone     String
  parentEmail     String?
  parentAddress   String?

  // Academic Information
  classId         String
  class           Class    @relation(fields: [classId], references: [id])
  entryClass      String?
  admissionDate   DateTime?

  // Student Information
  gender          String?
  dateOfBirth     DateTime?
  sportHouseId    String?
 

  // Health Information
  bloodGroup      String?
  genotype        String?

  // Physical Information
  height          Float?
  weight          Float?

  // Media
  passportPhoto   String?

  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  //sportHouse          SportHouse? @relation(fields: [sportHouseId], references: [id])
  sportHouse          String?
  payments            Payment[]
  results             Result[]
  optionalFeeAssigns  OptionalFeeAssign[]
  optionalFeePayments OptionalFeePayment[]

  assessments Assessment[]

  attendanceSummaries AttendanceSummary[]
}

// model SportHouse {
//   id       String    @id @default(cuid())
//   name     String
//   color    String?
//   motto    String?

//   students Student[]
// }

model AssessmentCategory {
  id          String @id @default(cuid())
  name        String
  type        String
  description String?

  assessments Assessment[]
  @@unique([name, type])
}

model Assessment {
  id          String @id @default(cuid())

  studentId   String
  termId      String

  categoryId  String

  score       String?
  remark      String?

  student     Student @relation(fields: [studentId], references: [id])
  term        Term @relation(fields: [termId], references: [id])
  category    AssessmentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([studentId, termId, categoryId])
}

// Payments (school fees) 

model Payment {
  id            String   @id @default(cuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  termId        String
  term          Term     @relation(fields: [termId], references: [id])
  amountPaid    Float
  currentBalance Float?
  paymentMethod String
  note          String?
  recordedById  String?  // User.id who recorded this
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
}

// Optional Fees 

model OptionalFee {
  id          String              @id @default(cuid())
  name        String              @unique
  amount      Float
  description String?
  createdAt   DateTime            @default(now())
  assigns     OptionalFeeAssign[]
}

model OptionalFeeAssign {
  id            String             @id @default(cuid())
  studentId     String
  student       Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  optionalFeeId String
  optionalFee   OptionalFee        @relation(fields: [optionalFeeId], references: [id], onDelete: Cascade)
  termId        String
  term          Term               @relation(fields: [termId], references: [id])
  createdAt     DateTime           @default(now())
  payments      OptionalFeePayment[]

  @@unique([studentId, optionalFeeId, termId])
}

model OptionalFeePayment {
  id                  String            @id @default(cuid())
  studentId           String
  student             Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  optionalFeeAssignId String
  optionalFeeAssign   OptionalFeeAssign @relation(fields: [optionalFeeAssignId], references: [id], onDelete: Cascade)
  amountPaid          Float
  paymentMethod       String
  note                String?
  recordedById        String?
  date                DateTime          @default(now())
  createdAt           DateTime          @default(now())
}

//Subjects & Results 

model Subject {
  id      String   @id @default(cuid())
  name    String
  classId String
  class   Class    @relation(fields: [classId], references: [id])
  results Result[]

  @@unique([name, classId])
}

model AttendanceSummary {
  id String @id @default(cuid())

  studentId String
  termId String

  schoolOpened Int @default(0)
  present Int @default(0)
  punctual Int @default(0)

  sportsActivities Int @default(0)
  otherActivities Int @default(0)

  student Student @relation(fields:[studentId], references:[id])
  term Term @relation(fields:[termId], references:[id])

  @@unique([studentId, termId])
}



model Result {
  id           String @id @default(cuid())

  studentId    String
  subjectId    String
  termId       String

  attendanceScore Float? @default(0)
  assignmentScore Float? @default(0)
  ca1Score        Float? @default(0)
  ca2Score        Float? @default(0)
  examScore       Float? @default(0)

  TotalScore      Float? @default(0)

  recordedById String?
  createdAt DateTime @default(now())

  student Student @relation(fields:[studentId], references:[id])
  subject Subject @relation(fields:[subjectId], references:[id])
  term    Term    @relation(fields:[termId], references:[id])

  @@unique([studentId, subjectId, termId])
}

//Audit Log

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName   String   // snapshot in case user is deleted
  userRole   String
  action     String   // CREATE | UPDATE | DELETE | LOGIN
  entity     String   // Student | Payment | Result | Class | etc.
  entityId   String?
  detail     String?  // human-readable summary
  metadata   Json?    // full payload for debugging
  ip         String?
  createdAt  DateTime @default(now())
}

//Notifications 

model NotificationLog {
  id        String   @id @default(cuid())
  phone     String
  message   String
  type      String
  status    String
  createdAt DateTime @default(now())
}
